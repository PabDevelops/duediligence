{
  "name": "traqcker-user-stats-widget",
  "version": "1.0.0",
  "private": true,
  "description": "Widget de escritorio: usuarios registrados y activos de Traqcker en tiempo real",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.traqcker.userstatswidget",
    "productName": "Traqcker User Stats",
    "files": ["main.js", "preload.js", "index.html", "renderer.js", "style.css"],
    "win": {
      "target": ["nsis"],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Traqcker User Stats"
    }
  }
}
